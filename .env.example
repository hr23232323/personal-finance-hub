# ── Copy this file to `.env` and fill in what you want to use. ───────────────
# `.env` is gitignored. Nothing here is required to just import CSVs and browse.

# ── LLM (optional — only needed for the "Ask" / advisor chat) ────────────────
# The app speaks the OpenAI-compatible API, so you can point it at ANY provider
# or your own proxy by changing LLM_BASE_URL. Default is OpenRouter.
#
#   OpenRouter (default):  https://openrouter.ai/api/v1   (get a key at openrouter.ai/keys)
#   OpenAI:                https://api.openai.com/v1
#   Local (Ollama):        http://localhost:11434/v1      (key can be "ollama")
#   Your own proxy:        https://your-proxy.example/v1
#
# NOTE: When you use the chat, the transactions relevant to your question are
# sent to whatever endpoint this points at. Manual/local-only stays fully local.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=anthropic/claude-opus-4.1

# ── SimpleFIN (optional — only needed for automatic bank sync) ───────────────
# You do NOT set this by hand. Get a one-time "setup token" from
# https://beta-bridge.simplefin.org , then paste it into the app's Connect box.
# The app exchanges it once and stores the access URL in the local DB.
# (Left here only so you know it exists.)
# SIMPLEFIN_SETUP_TOKEN=

# ── Storage (optional) ──────────────────────────────────────────────────────
# Where the local SQLite file lives. Defaults to ./data/finance.db
# DB_PATH=
